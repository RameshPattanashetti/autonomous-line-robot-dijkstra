<?xml version="1.0"?>
<robot name="line_robot">

  <link name="base_footprint"/>

  <!-- BODY -->
  <link name="base_link">
    <visual>
      <geometry><box size="0.18 0.16 0.06"/></geometry>
      <material name="blue"><color rgba="0.1 0.5 0.9 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.18 0.16 0.06"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.006" ixy="0" ixz="0" iyy="0.006" iyz="0" izz="0.010"/>
    </inertial>
  </link>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.033" rpy="0 0 0"/>
  </joint>

  <!-- LEFT WHEEL -->
  <link name="left_wheel">
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.033" length="0.022"/></geometry>
      <material name="black"><color rgba="0.05 0.05 0.05 1"/></material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.033" length="0.022"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0002"/>
    </inertial>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.095 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- RIGHT WHEEL -->
  <link name="right_wheel">
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.033" length="0.022"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.033" length="0.022"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0002"/>
    </inertial>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.095 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- CASTER -->
  <link name="caster_wheel">
    <visual>
      <geometry><sphere radius="0.012"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.012"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="0.075 0 -0.021" rpy="0 0 0"/>
  </joint>

  <!-- LIDAR LINK -->
  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="0.020" length="0.030"/></geometry>
      <material name="red"><color rgba="0.8 0.2 0.2 1"/></material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="2e-5" ixy="0" ixz="0" iyy="2e-5" iyz="0" izz="2e-5"/>
    </inertial>
  </link>
  <!-- lidar at z=0.046 above base_link → absolute z = 0.033+0.046 = 0.079m -->
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.046" rpy="0 0 0"/>
  </joint>

  <!-- DOWNWARD CAMERA LINK -->
  <link name="line_camera_link">
    <visual>
      <geometry><box size="0.035 0.025 0.018"/></geometry>
      <material name="green"><color rgba="0.1 0.8 0.2 1"/></material>
    </visual>
    <inertial>
      <mass value="0.03"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>
  <joint name="line_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="line_camera_link"/>
    <origin xyz="0.120 0 0.085" rpy="0 0 0"/>
  </joint>

  <!-- GAZEBO DIFF DRIVE PLUGIN -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.190</wheel_separation>
      <wheel_radius>0.033</wheel_radius>
      <odom_publish_frequency>20</odom_publish_frequency>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <tf_topic>/tf</tf_topic>
    </plugin>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>/joint_states</topic>
    </plugin>
  </gazebo>

  <!-- LIDAR SENSOR -->
  <gazebo reference="lidar_link">
    <sensor name="lidar" type="gpu_lidar">
      <topic>/scan</topic>
      <update_rate>20</update_rate>
      <gz_frame_id>lidar_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159265</min_angle>
            <max_angle>3.14159265</max_angle>
          </horizontal>
        </scan>
        <range><min>0.05</min><max>5.0</max><resolution>0.01</resolution></range>
        <noise><type>gaussian</type><mean>0</mean><stddev>0.001</stddev></noise>
      </lidar>
      <always_on>true</always_on>
      <visualize>false</visualize>
    </sensor>
  </gazebo>

  <!-- DOWNWARD CAMERA SENSOR FOR BLACK LINE DETECTION -->
  <gazebo reference="line_camera_link">
    <sensor name="line_camera" type="camera">
      <topic>/camera/image_raw</topic>
      <update_rate>20</update_rate>
      <gz_frame_id>line_camera_link</gz_frame_id>
      <pose>0 0 0 0 1.5708 0</pose>
      <camera>
        <horizontal_fov>1.5708</horizontal_fov>
        <image>
          <width>160</width>
          <height>120</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.01</near>
          <far>1.0</far>
        </clip>
      </camera>
      <always_on>true</always_on>
      <visualize>false</visualize>
    </sensor>
  </gazebo>

  <gazebo reference="caster_wheel"><mu1>0.0</mu1><mu2>0.0</mu2></gazebo>
  <gazebo reference="left_wheel"><mu1>2.0</mu1><mu2>0.5</mu2></gazebo>
  <gazebo reference="right_wheel"><mu1>2.0</mu1><mu2>0.5</mu2></gazebo>

</robot>
